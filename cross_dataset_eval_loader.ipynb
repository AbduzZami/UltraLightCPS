def load_metadata(DATA_DIR):
    df = pd.read_csv(os.path.join(DATA_DIR, 'metadata.csv'))
    df = df[['frame_id', 'png_image_path', 'png_mask_path']]
    df['png_image_path'] = df['png_image_path'].apply(lambda x: os.path.join(DATA_DIR, x))
    df['png_mask_path'] = df['png_mask_path'].apply(lambda x: os.path.join(DATA_DIR, x))
    return df

